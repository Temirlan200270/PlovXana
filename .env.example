# ---------------------------------------------------------------------------
# Локальный запуск (npm run dev) без своего Supabase
# ---------------------------------------------------------------------------
# 1) Скопируйте этот файл:  .env.example  ->  .env.local
# 2) Оставьте строки Supabase ниже пустыми — сайт возьмёт пилотного тенанта из кода,
#    на /plovxana/menu будет подсказка «режим без Supabase».
# 3) Если Next занял не 3000-й порт, выставьте тот же URL (см. вывод next dev):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# ---------------------------------------------------------------------------
# Supabase (публичные ключи безопасны для браузера; RLS защищает данные)
# ---------------------------------------------------------------------------
# Не подставляйте невалидный URL (например одно «https://» без хоста) — тогда dev упадёт в middleware.
# Если Supabase пока нет: оставьте обе строки пустыми или закомментируйте их.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Только на сервере (Vercel / .env.local). Не коммитить. Нужен для оформления заказа (guest write после валидации).
# SUPABASE_SERVICE_ROLE_KEY=

# Опционально: строгий smoke (scripts/smoke.mjs) — упасть, если service role не задан (см. docs/deployment-runbook.md)
# SMOKE_REQUIRE_SERVICE_ROLE=1

# Пилотный slug, если резолв по поддомену не сработал (см. lib/tenant/getTenant.ts)
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=plovxana

# Опционально: тот же uuid, что в lib/tenant/pilotTenant.ts — при сидировании tenants в Supabase
# NEXT_PUBLIC_PILOT_TENANT_ID=a0000000-0000-4000-8000-000000000001

# Опционально: Python FastAPI-адаптер iiko (см. services/iiko/getIikoMenu.ts)
IIKO_ADAPTER_URL=http://127.0.0.1:8090

# iiko API login (для TS iiko client в lib/services/iiko)
IIKO_API_LOGIN=

# Опционально: Telegram — уведомление владельцу о новом заказе (только сервер; не NEXT_PUBLIC_*)
# TELEGRAM_BOT_TOKEN=
# Fallback chat, если у tenant не задан telegram_chat_id в БД (после миграции 20260425_tenant_telegram.sql)
# TELEGRAM_CHAT_ID=
