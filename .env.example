# ---------------------------------------------------------------------------
# Локальный запуск (npm run dev) без своего Supabase
# ---------------------------------------------------------------------------
# 1) Скопируйте этот файл:  .env.example  ->  .env.local
# 2) Оставьте Supabase-строки пустыми — сайт возьмёт пилотного tenant из кода.
# 3) Если Next занял не 3000-й порт — поправьте NEXT_PUBLIC_SITE_URL.
#
# ---------------------------------------------------------------------------
# Supabase (read-only витрина: только anon key, никакого service_role)
# ---------------------------------------------------------------------------
# Указывайте тот же проект Supabase, что использует бот (БД с organizations + menu_items).
# RLS должен разрешать SELECT в `public.organizations` и `public.menu_items` для роли `anon`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Tenant и SEO
# ---------------------------------------------------------------------------
# Дефолтный slug, если резолв по поддомену/пути не сработал (см. lib/tenant/getTenant.ts).
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=plovxana

# Базовый URL сайта для канонических ссылок и Sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Кнопка «Заказать» в меню
# ---------------------------------------------------------------------------
# Ссылка, на которую ведёт CTA «Заказать в Telegram» (можно использовать https://t.me/your_bot?start=plovxana).
# Если переменная не задана — кнопка не показывается.
NEXT_PUBLIC_ORDER_URL=
