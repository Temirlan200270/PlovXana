# =============================================================================
# Plovxana — .gitignore (Next.js / Node)
# =============================================================================

# --- Dependencies ------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.pnp.cjs
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store/

# --- Next.js build & runtime -------------------------------------------------
.next/
out/
build/
dist/
.swc/
.turbo/
*.tsbuildinfo
next-env.d.ts.bak

# --- Environment Variables (never commit) ------------------------------------
# .env.example is committed intentionally as a template.
.env
.env.*
!.env.example

# --- Logs --------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# --- Caches and Tests --------------------------------------------------------
.cache/
.eslintcache
.stylelintcache
coverage/
.nyc_output/
.vitest-cache/
.test-results/
playwright-report/
test-results/

# --- Deployment Tools --------------------------------------------------------
.vercel/
.netlify/
.firebase/

# --- Supabase CLI ------------------------------------------------------------
supabase/.branches/
supabase/.temp/
supabase/logs/

# --- MCP / Agentation --------------------------------------------------------
.agentation/
.mcp-cache/

# --- IDE & Editors -----------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
*.sublime-project
*.sublime-workspace
.history/
.zed/
.cursorignore
.cursorindexingignore

# --- PM2 / runtime on VPS ----------------------------------------------------
.pm2/
ecosystem.config.local.js
pids/
*.pid
*.seed
*.pid.lock

# --- OS Artifacts ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# --- Temporary Project Files -------------------------------------------------
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej

# --- Secrets and Keys (fallback patterns) ------------------------------------
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
credentials/

# --- Personal / local notes (never commit) -----------------------------------
VPS_ACCESS.md
NOTES.local.md

# --- Personal VPS bootstrap scripts (contain embedded private SSH key) ------
setup-vps-access.ps1
setup-vps-access.bat

# --- Auto-generated screenshots from scripts/screenshots.mjs ----------------
screenshots/
